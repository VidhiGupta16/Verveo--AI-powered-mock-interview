APP_NAME=Verveo
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
OTP_EXPIRE_MINUTES=10
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/verveo
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:5173
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@verveo.ai
UPLOAD_DIR=uploads
UPLOADS_RESUMES_DIR=uploads/resumes
UPLOADS_AUDIO_DIR=uploads/audio
UPLOADS_VIDEO_DIR=uploads/video
CHROMA_DIR=chroma
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_OUTPUT_DIMENSIONALITY=256
WHISPER_MODEL_SIZE=base
FFMPEG_BINARY=ffmpeg
MAX_UPLOAD_SIZE_MB=10
